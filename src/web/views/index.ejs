<%- include('layout', { title: title, user: user }) %>

<div class="jumbotron bg-light p-5 rounded-3 mb-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-7">
                <h1 class="display-4">Discord抽獎機器人</h1>
                <p class="lead">輕鬆舉辦抽獎活動，提高伺服器活躍度！</p>
                <hr class="my-4">
                <p>GiveawayBot是一個功能強大的Discord機器人，可以幫助您在伺服器中舉辦各種抽獎活動。無論是贈送遊戲、禮品卡還是特殊角色，GiveawayBot都能讓抽獎過程變得簡單而有趣。</p>
                <div class="d-flex gap-2 mt-4">
                    <a href="https://discord.com/api/oauth2/authorize?client_id=<%= process.env.CLIENT_ID %>&permissions=8&scope=bot%20applications.commands" class="btn btn-primary btn-lg">
                        <i class="fas fa-plus-circle me-2"></i>邀請機器人
                    </a>
                    <% if (!user) { %>
                        <a href="/login" class="btn btn-outline-primary btn-lg">
                            <i class="fab fa-discord me-2"></i>使用Discord登入
                        </a>
                    <% } else { %>
                        <a href="/dashboard" class="btn btn-outline-primary btn-lg">
                            <i class="fas fa-tachometer-alt me-2"></i>前往控制面板
                        </a>
                    <% } %>
                </div>
            </div>
            <div class="col-md-5 d-none d-md-block">
                <img src="/img/giveaway-illustration.svg" alt="抽獎插圖" class="img-fluid">
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h2 class="mb-4">為什麼選擇GiveawayBot？</h2>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-bolt text-primary fa-3x mb-3"></i>
                    <h5 class="card-title">簡單易用</h5>
                    <p class="card-text">使用斜線命令，只需幾秒鐘即可設置抽獎活動。無需複雜的設置或配置。</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-cogs text-primary fa-3x mb-3"></i>
                    <h5 class="card-title">高度可定制</h5>
                    <p class="card-text">自定義抽獎持續時間、獲獎人數、嵌入顏色、參與要求等。創建完全符合您需求的抽獎活動。</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-chart-line text-primary fa-3x mb-3"></i>
                    <h5 class="card-title">詳細統計</h5>
                    <p class="card-text">查看參與率、完成率和其他有價值的統計數據，幫助您了解抽獎活動的效果。</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12 text-center">
            <h2 class="mb-4">主要功能</h2>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-gift text-primary me-2"></i>抽獎管理</h5>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">創建抽獎活動 (/gcreate)</li>
                        <li class="list-group-item">快速開始抽獎 (/gstart)</li>
                        <li class="list-group-item">結束抽獎 (/gend)</li>
                        <li class="list-group-item">刪除抽獎 (/gdelete)</li>
                        <li class="list-group-item">重新抽取獲獎者 (/greroll)</li>
                        <li class="list-group-item">列出當前抽獎 (/glist)</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-sliders-h text-primary me-2"></i>高級設置</h5>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">角色要求（限制特定角色參與）</li>
                        <li class="list-group-item">伺服器加入時間要求</li>
                        <li class="list-group-item">Discord帳戶年齡要求</li>
                        <li class="list-group-item">自定義嵌入顏色</li>
                        <li class="list-group-item">自定義抽獎表情符號</li>
                        <li class="list-group-item">多語言支持</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12 text-center">
            <h2 class="mb-4">開始使用</h2>
            <p class="lead mb-4">只需三個簡單步驟，即可開始在您的伺服器中舉辦抽獎活動</p>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="bg-primary text-white rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 50px; height: 50px;">
                        <span class="fs-4">1</span>
                    </div>
                    <h5 class="card-title">邀請機器人</h5>
                    <p class="card-text">將GiveawayBot添加到您的Discord伺服器。</p>
                    <a href="https://discord.com/api/oauth2/authorize?client_id=<%= process.env.CLIENT_ID %>&permissions=8&scope=bot%20applications.commands" class="btn btn-primary">
                        <i class="fas fa-plus-circle me-2"></i>邀請機器人
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="bg-primary text-white rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 50px; height: 50px;">
                        <span class="fs-4">2</span>
                    </div>
                    <h5 class="card-title">創建抽獎</h5>
                    <p class="card-text">使用/gcreate命令或Web控制面板創建抽獎活動。</p>
                    <% if (!user) { %>
                        <a href="/login" class="btn btn-primary">
                            <i class="fab fa-discord me-2"></i>登入控制面板
                        </a>
                    <% } else { %>
                        <a href="/dashboard" class="btn btn-primary">
                            <i class="fas fa-tachometer-alt me-2"></i>前往控制面板
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="bg-primary text-white rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 50px; height: 50px;">
                        <span class="fs-4">3</span>
                    </div>
                    <h5 class="card-title">管理抽獎</h5>
                    <p class="card-text">使用機器人命令或Web控制面板管理您的抽獎活動。</p>
                    <a href="#" class="btn btn-primary">
                        <i class="fas fa-book me-2"></i>查看文檔
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
